APP_NAME=i-home.life
APP_VERSION=1.0.0
DEBUG=true

# 数据库: 开发用 SQLite, 生产切换 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./data/ihome.db
# 生产 PostgreSQL: postgresql+asyncpg://user:pass@localhost:5432/ihome

# Redis 缓存（留空禁用，使用内存字典降级）
REDIS_URL=
# 生产: redis://localhost:6379/0

# 对象存储 OSS（留空使用本地文件存储）
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=ihome-assets
OSS_REGION=cn-hangzhou

# 向量数据库 RAG（留空禁用语义检索）
VECTOR_DB_URL=
VECTOR_DB_COLLECTION=ihome_knowledge
# Qdrant: http://localhost:6333
# Milvus: http://localhost:19530

PASETO_SECRET_KEY=please-generate-a-strong-random-key-at-least-32-bytes

# DeepSeek V4 API 配置（留空使用 mock 模式，填入真实 key 启用 LLM 调用）
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# GLM-5.2 (智谱 AI) API 配置（可选，与 DeepSeek 互为补充）
GLM_API_KEY=
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-plus

# 高德地图 Web API Key（用于地址智能补全、定位）
AMAP_API_KEY=
