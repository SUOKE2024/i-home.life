APP_NAME=i-home.life
APP_VERSION=1.1.0
DEBUG=true

# 数据库: 开发用 SQLite, 生产切换 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./data/ihome.db
# 生产 PostgreSQL: postgresql+asyncpg://user:pass@localhost:5432/ihome

# Redis 缓存（留空禁用，使用内存字典降级）
REDIS_URL=
# 生产: redis://localhost:6379/0

# 对象存储 OSS（留空使用本地文件存储）
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=ihome-assets
OSS_REGION=cn-hangzhou

# 向量数据库 RAG（留空禁用语义检索）
VECTOR_DB_URL=
VECTOR_DB_COLLECTION=ihome_knowledge
# Qdrant: http://localhost:6333
# Milvus: http://localhost:19530

PASETO_SECRET_KEY=please-generate-a-strong-random-key-at-least-32-bytes

# DeepSeek V4 API 配置（留空使用 mock 模式，填入真实 key 启用 LLM 调用）
# 模型名必须全小写: deepseek-v4-pro / deepseek-v4-flash / deepseek-chat
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# GLM (智谱 AI) API 配置（可选，与 DeepSeek 互为补充；余额不足时留空）
GLM_API_KEY=
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-plus

# Qwen-Audio-3.0-Realtime (阿里云百炼 DashScope)
# 字段名必须为 QWEN_AUDIO_API_KEY (与 app/config.py 对齐)，DASHSCOPE_API_KEY 不会被读取
# 留空则语音服务走 mock 模式 (ASR/TTS/双工)
QWEN_AUDIO_API_KEY=

# 高德地图 Web API Key（用于地址智能补全、定位）
AMAP_API_KEY=

# 阿里云身份证实名认证 AppCode（留空使用 Mock 模式，不调用真实核验）
ALIYUN_ID_VERIFY_APPCODE=

# WebAuthn / Passkey 生物识别认证（v1.0.5 新增）
# RP ID 必须与 WEBAUTHN_ORIGIN 的 host 一致（WebAuthn 规范要求）
# 开发环境: localhost / http://localhost:8766
# 生产环境: 域名或 IP / http://your-host:port (HTTP) 或 https://your-host:port (HTTPS)
# 注意: WebAuthn 要求 Secure Context (HTTPS 或 localhost)，HTTP 模式下 Passkey 不可用
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:8766
WEBAUTHN_CHALLENGE_TTL=120
# 注意: 多 worker 部署时务必启用 REDIS_URL，否则挑战不共享会导致登录失败
