APP_NAME=索克家居
APP_VERSION=1.1.0
DEBUG=false

# 数据库: 生产环境使用 SQLite（数据目录在 /opt/ihome/data/）
DATABASE_URL=sqlite+aiosqlite:///./data/ihome.db

# PASETO 密钥（生产环境务必使用强随机密钥，至少 32 字节）
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
PASETO_SECRET_KEY=please-replace-with-strong-random-key

# DeepSeek API（留空使用 mock 模式）
# 模型名必须全小写: deepseek-v4-pro / deepseek-v4-flash / deepseek-chat
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# GLM (智谱 AI)（余额不足时留空）
GLM_API_KEY=
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-plus

# Qwen-Audio-3.0-Realtime (阿里云百炼 DashScope)
# 字段名必须为 QWEN_AUDIO_API_KEY (与 app/config.py 对齐)；留空则语音服务走 mock 模式
QWEN_AUDIO_API_KEY=
# 实时语音模型: qwen-audio-3.0-realtime-flash (快速) | qwen-audio-3.0-realtime-plus (推理强)
QWEN_AUDIO_MODEL=qwen-audio-3.0-realtime-flash
# 百炼 Realtime WebSocket 地址
QWEN_AUDIO_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
# 默认音色: cherry | zhidan | longxiaochun | longanqian 等
QWEN_AUDIO_VOICE=cherry
# 情绪检测开关
VOICE_EMOTION_DETECTION=true
# Agent FunctionCall 工具调用开关
AGENT_FUNCTION_CALL_ENABLED=true
# 轮次检测模式: server_vad (声学VAD) | smart_turn (声学+语义) | none (手动按键说话)
VOICE_TURN_DETECTION=server_vad
# 说话人增强（声纹锁定，工地多人场景建议启用）
VOICE_AUDIO_PROMPT_ENABLED=false

# 高德地图 Web API Key
AMAP_API_KEY=

# WebAuthn / Passkey
# RP ID 必须与 Origin 的 host 完全一致（WebAuthn 规范要求）
# 注意: WebAuthn 要求 Secure Context (HTTPS 或 localhost)，HTTP 模式下 Passkey 不可用
WEBAUTHN_RP_ID=your-host-or-ip
WEBAUTHN_ORIGIN=http://your-host:port

# Redis (留空则使用内存字典降级；多 worker 部署时建议启用)
REDIS_URL=redis://127.0.0.1:6379/0

# CORS 允许的来源
CORS_ORIGINS=["http://your-host:port"]
