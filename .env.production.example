APP_NAME=索克家居
APP_VERSION=1.1.10
DEBUG=false

# ─────────────────────────────────────────────────────────────
# 数据库：阿里云 PolarDB for PostgreSQL（100% 兼容 PG 协议）
# ─────────────────────────────────────────────────────────────
# 推荐配置：PolarDB-PG 集群版（主备高可用）+ 通用型 4 核 8GB 起步
# 字符集：UTF8 | 时区：Asia/Shanghai（与 Python 应用层一致）
# 网络：建议与 ECS 同 VPC 内网访问（pc-xxxxx.pg.rds.aliyuncs.com:5432）
# SSL：PolarDB 默认支持 SSL，内网访问可关闭（?sslmode=disable），公网必须启用（?sslmode=require）
#
# 格式：postgresql+asyncpg://{user}:{password}@{host}:{port}/{dbname}?{params}
# 示例：
DATABASE_URL=postgresql+asyncpg://ihome:strong-password@pc-xxxxx.pg.rds.aliyuncs.com:5432/ihome?sslmode=require
#
# 本地开发回退（仅 DEBUG 用）：
# DATABASE_URL=sqlite+aiosqlite:///./data/ihome.db
#
# 连接池调优（asyncpg 默认池大小 5，生产建议通过 uvicorn --workers 控制）：
#   - 单 worker 模式：进程内 asyncpg 自动管理连接池，建议 max_size=20
#   - 多 worker 模式（--workers 4）：总连接数 = 4 × 20 = 80，需确保 PolarDB max_connections ≥ 100
#
# 兼容性说明（代码层零改动）：
#   - 所有模型主键使用 String(36) + Python uuid4()（避免 PG 原生 UUID 类型依赖）
#   - JSON 字段自动映射为 JSONB（性能更好，支持 GIN 索引）
#   - 外键约束 PG 严格检查，迁移前需确保数据完整性
#   - app/database.py 已通过 if "sqlite" in url 自动切换 StaticPool（仅 SQLite）

# ─────────────────────────────────────────────────────────────
# Redis：阿里云 Tair（Redis 兼容版）/ 云数据库 Redis 版
# ─────────────────────────────────────────────────────────────
# 推荐配置：Tair 持久化版 1GB 起步（含 RDB+AOF 双持久化）
# 网络：与 ECS 同 VPC 内网访问（r-xxxxx.redis.rds.aliyuncs.com:6379）
# 鉴权：阿里云 Redis 默认开启 ACL，密码格式为 {user}:{password}
#
# 格式：redis://:{password}@{host}:{port}/{db}  或  redis://{user}:{password}@{host}:{port}/{db}
# 示例（默认账号 default）：
REDIS_URL=redis://default:strong-password@r-xxxxx.redis.rds.aliyuncs.com:6379/0
#
# 留空则使用内存字典降级（单 worker 开发模式可用，多 worker 部署必须启用）
# 使用场景：
#   1. WebAuthn 挑战存储（app/services/webauthn_service.py）
#   2. 健康检查 /health 自动 ping（app/main.py）
#   3. 未来：API 限流、会话缓存、分布式锁

# PASETO 密钥（生产环境务必使用强随机密钥，至少 32 字节）
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
PASETO_SECRET_KEY=please-replace-with-strong-random-key

# DeepSeek API（留空使用 mock 模式）
# 模型名必须全小写: deepseek-v4-pro / deepseek-v4-flash / deepseek-chat
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# GLM (智谱 AI)（余额不足时留空）
GLM_API_KEY=
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-plus

# Qwen-Audio-3.0-Realtime (阿里云百炼 DashScope)
QWEN_AUDIO_API_KEY=
QWEN_AUDIO_MODEL=qwen-audio-3.0-realtime-flash
QWEN_AUDIO_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
QWEN_AUDIO_VOICE=cherry
VOICE_EMOTION_DETECTION=true
AGENT_FUNCTION_CALL_ENABLED=true
VOICE_TURN_DETECTION=server_vad
VOICE_AUDIO_PROMPT_ENABLED=false

# 高德地图 Web API Key
AMAP_API_KEY=

# WebAuthn / Passkey
# RP ID 必须与 Origin 的 host 完全一致（WebAuthn 规范要求）
# 注意: WebAuthn 要求 Secure Context (HTTPS 或 localhost)
WEBAUTHN_RP_ID=your-host-or-ip
WEBAUTHN_ORIGIN=https://your-host

# CORS 允许的来源
CORS_ORIGINS=["https://your-host"]
