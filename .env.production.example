APP_NAME=索克家居
APP_VERSION=1.1.0
DEBUG=false

# 数据库: 生产环境使用 SQLite（数据目录在 /opt/ihome/data/）
DATABASE_URL=sqlite+aiosqlite:///./data/ihome.db

# PASETO 密钥（生产环境务必使用强随机密钥，至少 32 字节）
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
PASETO_SECRET_KEY=please-replace-with-strong-random-key

# DeepSeek API（留空使用 mock 模式）
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# GLM (智谱 AI)
GLM_API_KEY=
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-plus

# 高德地图 Web API Key
AMAP_API_KEY=

# WebAuthn / Passkey
# RP ID 必须与 Origin 的 host 完全一致（WebAuthn 规范要求）
# 注意: WebAuthn 要求 Secure Context (HTTPS 或 localhost)，HTTP 模式下 Passkey 不可用
WEBAUTHN_RP_ID=your-host-or-ip
WEBAUTHN_ORIGIN=http://your-host:port

# Redis (留空则使用内存字典降级；多 worker 部署时建议启用)
REDIS_URL=redis://127.0.0.1:6379/0

# CORS 允许的来源
CORS_ORIGINS=["http://your-host:port"]
